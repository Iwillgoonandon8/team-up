<view class="container">

  <!-- 公告 -->
  <view class="notice-banner" wx:if="{{siteConfig.notice}}">
    <text class="notice-icon">📢</text>
    <text class="notice-text">{{siteConfig.notice}}</text>
  </view>

  <!-- 报名状态提示 -->
  <view class="status-banner closed-banner" wx:if="{{siteConfig && !siteConfig.teamRegOpen}}">
    🔒 组队报名当前已关闭
  </view>

  <!-- 搜索栏 -->
  <view class="search-bar">
    <input class="search-input" placeholder="搜索队名..." value="{{teamNameInput}}" bindinput="onTeamNameInput" bindconfirm="onTeamNameSearch" />
    <button class="search-btn" bindtap="onTeamNameSearch">搜索</button>
  </view>

  <!-- 阶段筛选 -->
  <scroll-view class="stage-scroll" scroll-x>
    <view class="stage-tabs">
      <view
        class="stage-tab {{filterStage === '' ? 'active' : ''}}"
        bindtap="onStageChange" data-stage="">全部</view>
      <view
        wx:for="{{stages}}" wx:key="*this"
        class="stage-tab {{filterStage === item ? 'active' : ''}}"
        bindtap="onStageChange" data-stage="{{item}}">{{item}}</view>
    </view>
  </scroll-view>

  <!-- 招募状态筛选 -->
  <view class="filter-tabs">
    <view class="filter-tab {{filterStatus === '' ? 'active' : ''}}" bindtap="onStatusChange" data-status="">全部</view>
    <view class="filter-status {{filterStatus === 'open' ? 'active' : ''}}" bindtap="onStatusChange" data-status="open">招募中</view>
  </view>

  <!-- 队伍列表 -->
  <block wx:if="{{teams.length > 0}}">
    <view class="card team-card" wx:for="{{teams}}" wx:key="team_id" bindtap="goDetail" data-team-id="{{item.team_id}}">
      <view class="team-header">
        <text class="team-name">{{item.team_name}}</text>
        <view class="{{item.recruit_status === 'open' ? 'status-open' : 'status-closed'}}">
          {{item.recruit_status === 'open' ? '招募中' : '已满员'}}
        </view>
      </view>
      <view class="team-tags">
        <view class="tag tag-blue">{{item.topic}}</view>
        <view class="tag tag-yellow" wx:if="{{item.stage}}">{{item.stage}}</view>
      </view>
      <view class="team-footer">
        <text class="team-members">👥 {{item.current_members}} / {{item.max_members}} 人</text>
        <text class="team-arrow">›</text>
      </view>
    </view>

    <view class="load-more" wx:if="{{!hasMore}}">
      <text>— 已加载全部 {{total}} 个队伍 —</text>
    </view>
    <view class="load-more" wx:if="{{loading && hasMore}}">
      <text>加载中...</text>
    </view>
  </block>

  <view class="empty" wx:elif="{{!loading}}">
    <text>{{siteConfig && !siteConfig.teamRegOpen ? '暂无队伍' : '暂无队伍，快去创建一个吧'}}</text>
  </view>

  <view class="empty" wx:elif="{{loading}}">
    <text>加载中...</text>
  </view>

</view>

<!-- 创建按钮（报名开放时才显示） -->
<view class="fab" bindtap="goCreate" wx:if="{{!siteConfig || siteConfig.teamRegOpen}}">+</view>
