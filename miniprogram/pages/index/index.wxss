.notice-banner {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  background: #e8f0fe;
  padding: 20rpx 24rpx;
  border-left: 6rpx solid #1a73e8;
}

.notice-icon { font-size: 28rpx; flex-shrink: 0; }
.notice-text { font-size: 26rpx; color: #1a73e8; line-height: 1.6; }

.status-banner {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
}

.closed-banner {
  background: #fce8e6;
  color: #ea4335;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #fff;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.search-input {
  flex: 1;
  height: 68rpx;
  background: #f5f7fa;
  border-radius: 34rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
}

.search-btn {
  background: #1a73e8;
  color: #fff;
  font-size: 26rpx;
  height: 68rpx;
  line-height: 68rpx;
  padding: 0 28rpx;
  border-radius: 34rpx;
  border: none;
  white-space: nowrap;
}

.stage-scroll {
  background: #fff;
  padding: 0 24rpx 12rpx;
}

.stage-tabs {
  display: inline-flex;
  gap: 12rpx;
}

.stage-tab {
  display: inline-flex;
  padding: 8rpx 24rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
  color: #666;
  background: #f5f7fa;
  white-space: nowrap;
  flex-shrink: 0;
}

.stage-tab.active {
  background: #fef7e0;
  color: #f9ab00;
  font-weight: 500;
}

.team-tags {
  display: flex;
  gap: 10rpx;
  margin-bottom: 20rpx;
  flex-wrap: wrap;
}

.filter-tabs {
  display: flex;
  background: #fff;
  padding: 0 24rpx 16rpx;
  gap: 16rpx;
}

.filter-tab {
  padding: 8rpx 28rpx;
  border-radius: 6rpx;
  font-size: 26rpx;
  color: #666;
  background: #f5f7fa;
}

.filter-tab.active {
  background: #e8f0fe;
  color: #1a73e8;
  font-weight: 500;
}

/* 招募状态筛选按钮：描边+圆点，与 stage 实心色块区分 */
.filter-status {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 28rpx;
  border-radius: 6rpx;
  font-size: 26rpx;
  border: 2rpx solid #bbb;
  color: #999;
  background: transparent;
}

.filter-status::before {
  content: '';
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #bbb;
  flex-shrink: 0;
}

.filter-status.active {
  border-color: #34a853;
  color: #34a853;
  font-weight: 500;
}

.filter-status.active::before {
  background: #34a853;
}

.team-card {
  cursor: pointer;
}

.team-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.team-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #222;
}

.team-topic {
  margin-bottom: 20rpx;
}

.team-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.team-members {
  font-size: 26rpx;
  color: #666;
}

.team-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.load-more {
  text-align: center;
  padding: 24rpx;
  color: #999;
  font-size: 24rpx;
}

.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 100rpx;
  height: 100rpx;
  background: #1a73e8;
  border-radius: 50%;
  color: #fff;
  font-size: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 20rpx rgba(26, 115, 232, 0.4);
}
