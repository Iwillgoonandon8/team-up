.user-card {
  padding: 20rpx 28rpx;
}

.user-label {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-bottom: 12rpx;
}

.user-id {
  font-size: 24rpx;
  color: #333;
  word-break: break-all;
}

.user-input {
  flex: 1;
  height: 64rpx;
  background: #f5f7fa;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #333;
}

.tabs {
  display: flex;
  background: #fff;
  margin-bottom: 4rpx;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  font-size: 28rpx;
  color: #999;
  position: relative;
}

.tab.active {
  color: #1a73e8;
  font-weight: 600;
  border-bottom: 4rpx solid #1a73e8;
}

.badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #ea4335;
  color: #fff;
  font-size: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  border-radius: 16rpx;
  padding: 0 8rpx;
  margin-left: 8rpx;
  vertical-align: middle;
}

.team-header-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 24rpx;
}

.team-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
}

.team-stats {
  display: flex;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx 0;
  margin-bottom: 24rpx;
}

.stat {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
}

.stat-num {
  font-size: 36rpx;
  font-weight: 700;
  color: #1a73e8;
}

.stat-num.green {
  color: #34a853;
}

.stat-num.gray {
  color: #999;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
}

.stat-divider {
  width: 2rpx;
  background: #e0e0e0;
  margin: 4rpx 0;
}

.apply-card {
  margin-top: 0;
}

.apply-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.apply-team {
  font-size: 24rpx;
  color: #999;
}

.apply-user {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  margin-bottom: 12rpx;
}

.apply-message {
  font-size: 26rpx;
  color: #666;
  margin-bottom: 20rpx;
  line-height: 1.6;
}

.admin-entry {
  text-align: center;
  padding: 40rpx 0 60rpx;
  font-size: 24rpx;
  color: #ccc;
}

.apply-actions {
  display: flex;
  gap: 20rpx;
  justify-content: flex-end;
}
