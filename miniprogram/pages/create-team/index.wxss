.status-banner {
  padding: 16rpx 24rpx;
  font-size: 26rpx;
  font-weight: 500;
  text-align: center;
  border-radius: 12rpx;
}

.closed-banner {
  background: #fce8e6;
  color: #ea4335;
}

.form-item {
  margin-bottom: 40rpx;
}

.form-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}
