<view class="status-banner closed-banner" wx:if="{{!teamRegOpen}}" style="margin: 24rpx 24rpx 0;">
  🔒 组队报名当前已关闭，暂不能创建队伍
</view>

<view class="card">
  <view class="form-item">
    <text class="form-label">队伍名称</text>
    <input
      class="form-input"
      placeholder="给你的队伍起个名字"
      value="{{teamName}}"
      bindinput="onInput"
      data-field="teamName"
      maxlength="30"
    />
  </view>

  <view class="form-item">
    <text class="form-label">学习阶段</text>
    <picker mode="selector" range="{{stages}}" value="{{stageIndex}}" bindchange="onStageChange">
      <view class="picker-val">{{stages[stageIndex]}} ▾</view>
    </picker>
  </view>

  <view class="form-item">
    <text class="form-label">话题 / 方向</text>
    <input
      class="form-input"
      placeholder="例如：NEMU实现、流水线设计..."
      value="{{topic}}"
      bindinput="onInput"
      data-field="topic"
      maxlength="30"
    />
  </view>

  <view class="form-item">
    <text class="form-label">最多成员数：{{maxMembers}} 人</text>
    <slider
      min="2"
      max="8"
      value="{{maxMembers}}"
      step="1"
      show-value
      activeColor="#1a73e8"
      bindchange="onMembersChange"
    />
  </view>

  <button
    class="btn btn-primary"
    style="margin-top: 16rpx;"
    bindtap="onSubmit"
    loading="{{submitting}}"
    disabled="{{submitting || !teamRegOpen}}"
  >
    创建队伍
  </button>
</view>
