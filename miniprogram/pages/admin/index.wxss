.lock-card {
  margin-top: 120rpx;
  display: flex;
  flex-direction: column;
}

.lock-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 32rpx;
  text-align: center;
}

.section-hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 24rpx;
}

.toggle {
  padding: 8rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.toggle.on {
  background: #e6f4ea;
  color: #34a853;
}

.toggle.off {
  background: #f1f3f4;
  color: #999;
}

.date-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 20rpx;
}

.date-label {
  font-size: 26rpx;
  color: #666;
  width: 120rpx;
  flex-shrink: 0;
}

.date-val {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  background: #f5f7fa;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #333;
}

.status-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.open { color: #34a853; font-weight: 500; }
.closed { color: #ea4335; font-weight: 500; }

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.btn-danger {
  background: #e53935;
  color: #fff;
  border: none;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
}
