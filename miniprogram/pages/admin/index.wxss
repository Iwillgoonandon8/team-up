.lock-card {
  margin-top: 120rpx;
  display: flex;
  flex-direction: column;
}

.key-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f7fa;
  border-radius: 12rpx;
}

.key-input {
  flex: 1;
  background: transparent;
  border-radius: 0;
}

.eye-btn {
  padding: 0 24rpx;
  font-size: 36rpx;
  flex-shrink: 0;
}

.lock-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 32rpx;
  text-align: center;
}

.section-hd {
  display: flex;
  justify-content: space-between;
  align-items: center;
  font-size: 30rpx;
  font-weight: 600;
  color: #222;
  margin-bottom: 24rpx;
}

.toggle {
  padding: 8rpx 28rpx;
  border-radius: 30rpx;
  font-size: 26rpx;
  font-weight: 500;
}

.toggle.on {
  background: #e6f4ea;
  color: #34a853;
}

.toggle.off {
  background: #f1f3f4;
  color: #999;
}

.date-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 20rpx;
}

.date-label {
  font-size: 26rpx;
  color: #666;
  width: 120rpx;
  flex-shrink: 0;
}

.date-val {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  background: #f5f7fa;
  border-radius: 10rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  color: #333;
}

.status-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 16rpx;
}

.open { color: #34a853; font-weight: 500; }
.closed { color: #ea4335; font-weight: 500; }

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.btn-danger {
  background: #e53935;
  color: #fff;
  border: none;
}

.stage-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.stage-row-hd {
  margin-bottom: 8rpx;
}

.stage-row-hd text {
  font-size: 22rpx;
  color: #999;
}

.stage-col-name {
  flex: 1;
}

.stage-col-max {
  width: 72rpx;
  flex-shrink: 0;
}

.stage-col-del {
  width: 40rpx;
  flex-shrink: 0;
}

/* 名称输入框：不设 width，让 flex:1 决定宽度 */
.stage-input-name {
  height: 64rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  padding: 0 16rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
  display: block;
}

/* 上限输入框：固定宽度列内撑满 */
.stage-input-max {
  width: 72rpx;
  height: 64rpx;
  background: #f5f7fa;
  border-radius: 8rpx;
  padding: 0 8rpx;
  font-size: 26rpx;
  color: #333;
  box-sizing: border-box;
  text-align: center;
}

.stage-del {
  width: 40rpx;
  height: 40rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ea4335;
  font-size: 28rpx;
  flex-shrink: 0;
}

.stage-add-row {
  margin-top: 8rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #f0f0f0;
}

.stage-add-btn {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #1a73e8;
  font-size: 36rpx;
  flex-shrink: 0;
}

.form-textarea {
  width: 100%;
  min-height: 120rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
}
