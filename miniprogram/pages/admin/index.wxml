<view>

  <!-- 未解锁：输入密钥 -->
  <view wx:if="{{unlocked === false}}" class="card lock-card">
    <text class="lock-title">🔐 管理员入口</text>
    <view class="key-input-wrap">
      <input
        class="form-input key-input"
        placeholder="输入管理员密钥"
        password="{{!showKey}}"
        value="{{keyInput}}"
        bindinput="onKeyInput"
      />
      <text class="eye-btn" bindtap="toggleShowKey">{{showKey ? '🙈' : '👁'}}</text>
    </view>
    <button class="btn btn-primary" style="margin-top: 24rpx;" bindtap="unlock">进入</button>
  </view>

  <!-- 已解锁：配置面板 -->
  <view wx:if="{{unlocked === true}}">

    <!-- 公告 -->
    <view class="card">
      <view class="section-hd">📢 公告（展示给所有学员）</view>
      <textarea
        class="form-textarea"
        placeholder="留空则不显示公告"
        value="{{notice}}"
        bindinput="onNoticeInput"
        maxlength="200"
      />
    </view>

    <!-- 组队报名 -->
    <view class="card">
      <view class="section-hd">
        <text>👥 创建/加入队伍</text>
        <view class="toggle {{teamRegEnabled ? 'on' : 'off'}}" bindtap="onToggle" data-field="teamRegEnabled">
          {{teamRegEnabled ? '开启' : '关闭'}}
        </view>
      </view>
      <view class="date-row">
        <text class="date-label">开放日期</text>
        <picker mode="date" value="{{teamRegOpenDate}}" bindchange="onDateChange" data-field="teamRegOpenDate">
          <view class="date-val">{{teamRegOpenDate || '不限'}}</view>
        </picker>
      </view>
      <view class="date-row">
        <text class="date-label">截止日期</text>
        <picker mode="date" value="{{teamRegCloseDate}}" bindchange="onDateChange" data-field="teamRegCloseDate">
          <view class="date-val">{{teamRegCloseDate || '不限'}}</view>
        </picker>
      </view>
      <view class="status-hint">
        当前状态：<text class="{{cfg.teamRegOpen ? 'open' : 'closed'}}">{{cfg.teamRegOpen ? '✅ 开放中' : '🔒 已关闭'}}</text>
      </view>
    </view>

    <!-- 打卡 -->
    <view class="card">
      <view class="section-hd">
        <text>📝 打卡</text>
        <view class="toggle {{checkinEnabled ? 'on' : 'off'}}" bindtap="onToggle" data-field="checkinEnabled">
          {{checkinEnabled ? '开启' : '关闭'}}
        </view>
      </view>
      <view class="date-row">
        <text class="date-label">开放日期</text>
        <picker mode="date" value="{{checkinOpenDate}}" bindchange="onDateChange" data-field="checkinOpenDate">
          <view class="date-val">{{checkinOpenDate || '不限'}}</view>
        </picker>
      </view>
      <view class="date-row">
        <text class="date-label">截止日期</text>
        <picker mode="date" value="{{checkinCloseDate}}" bindchange="onDateChange" data-field="checkinCloseDate">
          <view class="date-val">{{checkinCloseDate || '不限'}}</view>
        </picker>
      </view>
      <view class="status-hint">
        当前状态：<text class="{{cfg.checkinOpen ? 'open' : 'closed'}}">{{cfg.checkinOpen ? '✅ 开放中' : '🔒 已关闭'}}</text>
      </view>
    </view>

    <!-- 阶段配置 -->
    <view class="card">
      <view class="section-hd">📚 学习阶段与队伍上限</view>

      <view class="stage-row stage-row-hd">
        <text class="stage-col-name">阶段名称</text>
        <text class="stage-col-max">上限</text>
        <text class="stage-col-del"></text>
      </view>

      <view class="stage-row" wx:for="{{stagesConfig}}" wx:key="index">
        <view class="stage-col-name">
          <input
            class="stage-input-name"
            value="{{item.name}}"
            data-index="{{index}}"
            bindinput="onStageNameInput"
          />
        </view>
        <view class="stage-col-max">
          <input
            class="stage-input-max"
            type="number"
            value="{{item.maxTeams}}"
            data-index="{{index}}"
            bindinput="onStageMaxInput"
          />
        </view>
        <view class="stage-del stage-col-del" bindtap="onDeleteStage" data-index="{{index}}">✕</view>
      </view>

      <view class="stage-row stage-add-row">
        <view class="stage-col-name">
          <input
            class="stage-input-name"
            placeholder="新阶段名"
            value="{{newStageName}}"
            bindinput="onNewStageNameInput"
          />
        </view>
        <view class="stage-col-max">
          <input
            class="stage-input-max"
            type="number"
            placeholder="上限"
            value="{{newStageMax}}"
            bindinput="onNewStageMaxInput"
          />
        </view>
        <view class="stage-add-btn stage-col-del" bindtap="onAddStage">＋</view>
      </view>
    </view>

    <view style="padding: 0 24rpx 20rpx;">
      <button class="btn btn-primary" bindtap="onSave" loading="{{saving}}" disabled="{{saving}}">保存配置</button>
    </view>

    <!-- 新一期 -->
    <view class="card" style="margin-bottom: 0;">
      <view class="section-hd">🗂 开启新一期</view>
      <view style="font-size: 26rpx; color: #888; margin-bottom: 20rpx;">
        将存档所有现有队伍，学员可重新组队。此操作不可撤销。
      </view>
      <button class="btn btn-danger" bindtap="onArchiveTeams" loading="{{archiving}}" disabled="{{archiving}}">
        存档所有队伍，开启新一期
      </button>
    </view>

    <view style="padding: 24rpx 24rpx 60rpx;">
      <button class="btn btn-outline" bindtap="logout">退出管理员</button>
    </view>

  </view>

</view>
