.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.detail-name {
  font-size: 36rpx;
  font-weight: 700;
  color: #222;
}

.detail-row {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
  gap: 16rpx;
}

.label {
  font-size: 26rpx;
  color: #999;
  width: 80rpx;
  flex-shrink: 0;
}

.value {
  font-size: 28rpx;
  color: #333;
}

.notice-card {
  color: #666;
  font-size: 28rpx;
}

.apply-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  display: block;
  margin-bottom: 20rpx;
}

.apply-input {
  width: 100%;
  min-height: 180rpx;
  background: #f5f7fa;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  margin-bottom: 24rpx;
  box-sizing: border-box;
}
