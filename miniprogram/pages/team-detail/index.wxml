<view wx:if="{{team}}">

  <!-- 队伍基本信息 -->
  <view class="card">
    <view class="detail-header">
      <text class="detail-name">{{team.team_name}}</text>
      <view class="tag {{team.recruit_status === 'open' ? 'tag-green' : 'tag-gray'}}">
        {{team.recruit_status === 'open' ? '招募中' : '已满员'}}
      </view>
    </view>

    <view class="detail-tags">
      <view class="tag tag-yellow" wx:if="{{team.stage}}">{{team.stage}}</view>
      <view class="tag tag-blue">{{team.topic}}</view>
    </view>

    <view class="detail-row">
      <text class="label">成员</text>
      <text class="value">{{team.current_members}} / {{team.max_members}} 人</text>
    </view>
    <view class="detail-row">
      <text class="label">队长</text>
      <text class="value">{{team.leader_user_id}}</text>
    </view>
  </view>

  <!-- 我的队伍：显示打卡按钮 -->
  <view class="card action-card" wx:if="{{isMyTeam}}">
    <text class="action-label">✅ 这是你的队伍</text>
    <button class="btn btn-primary btn-sm" bindtap="goCheckin">📝 今日打卡</button>
  </view>

  <!-- 已申请 -->
  <view class="card notice-card" wx:elif="{{alreadyApplied}}">
    <text>⏳ 你已提交申请，等待审核</text>
  </view>

  <!-- 已有其他队伍 -->
  <view class="card notice-card" wx:elif="{{myTeam.hasTeam}}">
    <text>ℹ️ 你已经有队伍了，无法申请</text>
  </view>

  <!-- 申请区域 -->
  <view class="card" wx:elif="{{team.recruit_status === 'open'}}">
    <text class="apply-title">申请加入</text>
    <textarea
      class="apply-input"
      placeholder="介绍一下自己，为什么想加入这个队伍..."
      value="{{message}}"
      bindinput="onMessageInput"
      maxlength="200"
    />
    <button class="btn btn-primary" bindtap="onApply" loading="{{applying}}" disabled="{{applying}}">
      提交申请
    </button>
  </view>

  <view class="card notice-card" wx:elif="{{team.recruit_status !== 'open'}}">
    <text>🔒 该队伍已停止招募</text>
  </view>

  <!-- 打卡动态 -->
  <view class="section-title">打卡动态</view>

  <view wx:if="{{checkins.length === 0 && !loadingCheckins}}" class="empty">
    <text>暂无打卡记录</text>
  </view>

  <view class="card checkin-card" wx:for="{{checkins}}" wx:key="checkin_id">
    <view class="checkin-header">
      <text class="checkin-user">{{item.user_id}}</text>
      <view class="tag tag-yellow">{{item.stage}}</view>
    </view>
    <text class="checkin-milestone">🏁 {{item.milestone}}</text>
    <text class="checkin-content">{{item.content}}</text>
    <view class="checkin-blocked" wx:if="{{item.blocked_by}}">
      <text class="blocked-label">🚧 卡在：</text>
      <text class="blocked-text">{{item.blocked_by}}</text>
    </view>
    <text class="checkin-time">{{formatTime(item.created_at)}}</text>
  </view>

  <view class="load-more" wx:if="{{checkinHasMore}}" bindtap="onLoadMoreCheckins">
    <text>{{loadingCheckins ? '加载中...' : '加载更多'}}</text>
  </view>

</view>

<view class="empty" wx:else>
  <text>加载中...</text>
</view>
