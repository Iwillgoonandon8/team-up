page {
  background: #f5f7fa;
  font-family: -apple-system, "PingFang SC", sans-serif;
  color: #333;
}

.card {
  background: #fff;
  border-radius: 12rpx;
  padding: 28rpx;
  margin: 20rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  font-weight: 500;
  border: none;
}

.btn-primary {
  background: #1a73e8;
  color: #fff;
}

.btn-danger {
  background: #ea4335;
  color: #fff;
}

.btn-outline {
  background: #fff;
  color: #1a73e8;
  border: 2rpx solid #1a73e8;
}

.btn-sm {
  height: 56rpx;
  font-size: 24rpx;
  padding: 0 24rpx;
  border-radius: 28rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  font-size: 22rpx;
}

.tag-green {
  background: #e6f4ea;
  color: #34a853;
}

.tag-gray {
  background: #f1f3f4;
  color: #999;
}

.tag-blue {
  background: #e8f0fe;
  color: #1a73e8;
}

.tag-yellow {
  background: #fef7e0;
  color: #f9ab00;
}

.tag-red {
  background: #fce8e6;
  color: #ea4335;
}

/* 招募状态专用：描边 + 小圆点，与实心属性标签区分 */
.status-open {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  border: 2rpx solid #34a853;
  color: #34a853;
  font-size: 22rpx;
  background: transparent;
}

.status-open::before {
  content: '';
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #34a853;
  flex-shrink: 0;
}

.status-closed {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 16rpx;
  border-radius: 6rpx;
  border: 2rpx solid #bbb;
  color: #999;
  font-size: 22rpx;
  background: transparent;
}

.status-closed::before {
  content: '';
  display: inline-block;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #bbb;
  flex-shrink: 0;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  color: #999;
  font-size: 28rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #666;
  padding: 20rpx 24rpx 8rpx;
}
